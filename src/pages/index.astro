---
import { rooms } from '../lib/rooms.js';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Room Selection | VR House</title>
		<style>
			:root {
				--bg: #f1eee5;
				--panel: #fffef9;
				--text: #1a1f26;
				--muted: #52616b;
				--accent: #8f4a24;
				--shadow: 0 12px 40px rgba(48, 39, 28, 0.14);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				font-family: 'Sora', 'Segoe UI', sans-serif;
				color: var(--text);
				background:
					radial-gradient(circle at 8% 16%, #fff8e6 0%, transparent 38%),
					radial-gradient(circle at 90% 8%, #efe5ca 0%, transparent 30%),
					var(--bg);
			}

			main {
				width: min(1040px, 100% - 2rem);
				margin: 0 auto;
				padding: 3rem 0 4rem;
			}

			h1 {
				margin: 0 0 0.6rem;
				font-size: clamp(2rem, 4vw, 3rem);
				letter-spacing: -0.04em;
			}

			.subtitle {
				margin: 0;
				max-width: 70ch;
				line-height: 1.5;
				color: var(--muted);
			}

			.grid {
				margin-top: 2rem;
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
				gap: 1rem;
			}

			.card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				min-height: 180px;
				padding: 1rem;
				border-radius: 16px;
				background: var(--panel);
				box-shadow: var(--shadow);
			}

			.card h2 {
				margin: 0 0 0.5rem;
				font-size: 1.2rem;
			}

			.card p {
				margin: 0;
				color: var(--muted);
				line-height: 1.45;
			}

			.cta {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 1rem;
				padding: 0.65rem 0.9rem;
				border-radius: 999px;
				background: var(--accent);
				color: #fff;
				text-decoration: none;
				font-weight: 600;
				transition: transform 180ms ease, opacity 180ms ease;
			}

			.cta:hover {
				transform: translateY(-1px);
				opacity: 0.92;
			}

			.meta {
				margin-top: 0.6rem;
				font-size: 0.88rem;
				color: var(--muted);
			}

			.card-upload {
				border: 2px dashed color-mix(in srgb, var(--accent) 40%, transparent);
				background: color-mix(in srgb, var(--accent) 4%, var(--panel));
			}

			.card-upload input[type="file"] {
				display: none;
			}

			.cta-outline {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-top: 1rem;
				padding: 0.65rem 0.9rem;
				border-radius: 999px;
				border: 2px solid var(--accent);
				background: transparent;
				color: var(--accent);
				font: 600 1rem/1 inherit;
				cursor: pointer;
				transition: transform 180ms ease, background 180ms ease, color 180ms ease;
			}

			.cta-outline:hover {
				background: var(--accent);
				color: #fff;
				transform: translateY(-1px);
			}

			@media (max-width: 640px) {
				main {
					padding-top: 2rem;
				}
			}
		</style>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<main>
			<h1>Select a Room</h1>
			<p class="subtitle">
				Pick a room to launch the viewer. More scans can be added by extending the shared room config.
			</p>

			<section class="grid">
				{rooms.map((room) => (
					<article class="card">
						<div>
							<h2>{room.name}</h2>
							<p>{room.description}</p>
							{room.isMock ? <p class="meta">Mocked: currently uses the same model asset.</p> : null}
						</div>
						<a class="cta" href={`/viewer?room=${room.id}`}>Open Room</a>
					</article>
				))}
				<article class="card card-upload" id="upload-card">
					<div>
						<h2>Load from Drive</h2>
						<p>Open a local <strong>.glb</strong> or <strong>.gltf</strong> file directly from your device.</p>
					</div>
					<input type="file" id="local-model-input" accept=".glb,.gltf" />
					<button class="cta-outline" id="upload-btn">Choose File…</button>
				</article>
			</section>
		</main>

		<script>
			const btn = document.getElementById('upload-btn') as HTMLButtonElement;
			const input = document.getElementById('local-model-input') as HTMLInputElement;

			btn.addEventListener('click', () => input.click());

			input.addEventListener('change', async () => {
				const file = input.files?.[0];
				if (!file) return;

				btn.textContent = 'Reading file…';
				btn.disabled = true;

				const buffer = await file.arrayBuffer();

				// Store the raw bytes in IndexedDB — blob URLs are invalidated on navigation
				const db = await new Promise<IDBDatabase>((resolve, reject) => {
					const req = indexedDB.open('vrwebapp', 1);
					req.onupgradeneeded = () => req.result.createObjectStore('models');
					req.onsuccess = () => resolve(req.result);
					req.onerror = () => reject(req.error);
				});

				await new Promise<void>((resolve, reject) => {
					const tx = db.transaction('models', 'readwrite');
					tx.objectStore('models').put(buffer, 'localModel');
					tx.oncomplete = () => resolve();
					tx.onerror = () => reject(tx.error);
				});

				sessionStorage.setItem('localModelName', file.name);
				window.location.href = '/viewer?room=__local__';
			});
		</script>
	</body>
</html>
