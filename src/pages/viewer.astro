---
import { rooms } from '../lib/rooms.js';
import ViewerTopBar from '../components/ViewerTopBar.astro';
---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>VR Viewer | VR House</title>
    <style>
      :root {
        --panel: rgba(18, 23, 32, 0.76);
        --panel-border: rgba(255, 255, 255, 0.14);
        --text: #f6f5ef;
        --muted: #d7d4c4;
        --action: #db7f2a;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: 'Sora', 'Segoe UI', sans-serif;
        color: var(--text);
        background: #10141a;
      }

      #canvas-container {
        width: 100%;
        height: 100vh;
        position: relative;
      }

      @media (max-width: 640px) {
        body {
          font-size: 15px;
        }
      }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="canvas-container">
      <ViewerTopBar rooms={rooms} />
    </div>

    <script>
      import { initVRViewer } from '../lib/vrViewer.js';
      import { rooms } from '../lib/rooms.js';
      import { getLocalRoomShell, readLocalModelBlobUrl } from '../lib/localModelStore.js';

      type SurfaceKey = 'all' | 'walls' | 'ceiling' | 'floor' | 'objects';
      type ViewerController = {
        loadRoom: (room: (typeof rooms)[number]) => Promise<void>;
        getEditableSurfaceSummary: () => Record<SurfaceKey, number>;
        setSurfaceAppearance: (
          groupId: SurfaceKey,
          values: { color?: string; preset?: string; roughness?: number; metalness?: number }
        ) => { updated: number };
        resetSurfaceAppearance: (groupId?: SurfaceKey) => { updated: number };
        isVRSupported: () => boolean;
        startVRSession: (onStart?: () => void, onEnd?: () => void) => Promise<void>;
        dispose: () => void;
      };

      const container = document.getElementById('canvas-container') as HTMLDivElement;
      const roomSelect = document.getElementById('room-select') as HTMLSelectElement;
      const status = document.getElementById('status') as HTMLElement;
      const vrBtn = document.getElementById('vr-btn') as HTMLButtonElement;
      const materialTarget = document.getElementById('material-target') as HTMLSelectElement;
      const materialColor = document.getElementById('material-color') as HTMLInputElement;
      const materialPreset = document.getElementById('material-preset') as HTMLSelectElement;
      const materialRoughness = document.getElementById('material-roughness') as HTMLInputElement;
      const materialMetalness = document.getElementById('material-metalness') as HTMLInputElement;
      const materialApply = document.getElementById('material-apply') as HTMLButtonElement;
      const materialReset = document.getElementById('material-reset') as HTMLButtonElement;
      const materialStatus = document.getElementById('material-status') as HTMLElement;
      const topbar = document.querySelector('.topbar') as HTMLElement;
      const toggle = document.getElementById('topbar-toggle') as HTMLButtonElement;
      const localObjectUrls = new Set<string>();

      toggle.addEventListener('click', () => {
        const open = topbar.dataset.open === 'true';
        topbar.dataset.open = String(!open);
        toggle.setAttribute('aria-expanded', String(!open));
      });

      function getRoomFromUrl() {
        return new URL(window.location.href).searchParams.get('room');
      }

      function writeUrl(roomId: string) {
        const url = new URL(window.location.href);
        url.searchParams.set('room', roomId);
        window.history.replaceState({}, '', url);
      }

      function syncLocalRoomOption() {
        const existing = roomSelect.querySelector('option[value="__local__"]');
        const shell = getLocalRoomShell();

        if (!shell && existing) {
          existing.remove();
          return;
        }

        if (shell && !existing) {
          const option = document.createElement('option');
          option.value = '__local__';
          option.textContent = `Local: ${shell.name}`;
          roomSelect.insertBefore(option, roomSelect.firstChild);
          return;
        }

        if (shell && existing) {
          existing.textContent = `Local: ${shell.name}`;
        }
      }

      async function resolveRoomById(roomId: string | null) {
        if (roomId === '__local__') {
          const modelUrl = await readLocalModelBlobUrl();
          const shell = getLocalRoomShell();
          if (modelUrl && shell) {
            localObjectUrls.add(modelUrl);
            return { ...shell, modelUrl };
          }
          return null;
        }

        return rooms.find((room) => room.id === roomId) || null;
      }

      function refreshMaterialTargets(viewer: ViewerController) {
        const summary = viewer.getEditableSurfaceSummary();
        for (const option of materialTarget.options) {
          const key = option.value as SurfaceKey;
          const label = option.textContent?.split('(')[0]?.trim() || option.textContent || key;
          option.textContent = `${label} (${summary[key] ?? 0})`;
        }
      }

      syncLocalRoomOption();

      const initialRoomId = getRoomFromUrl();
      let activeRoom = await resolveRoomById(initialRoomId);

      if (!activeRoom) {
        activeRoom = rooms[0];
      }

      roomSelect.value = activeRoom.id;

      status.textContent = `Loading ${activeRoom.name}...`;
      let viewer: ViewerController;
      viewer = await initVRViewer(container, {
        initialRoom: activeRoom,
        onRoomChange(room: (typeof rooms)[number]) {
          activeRoom = room;
          roomSelect.value = room.id;
          status.textContent = room.isMock
            ? `${room.name} loaded (mock model)`
            : `${room.name} loaded`;
          refreshMaterialTargets(viewer);
        }
      });

      refreshMaterialTargets(viewer);

      function getMaterialValues() {
        const roughness = Number.parseFloat(materialRoughness.value);
        const metalness = Number.parseFloat(materialMetalness.value);
        const preset = materialPreset.value;

        return {
          color: materialColor.value,
          preset: preset === 'custom' ? undefined : preset,
          roughness,
          metalness
        };
      }

      materialApply.addEventListener('click', () => {
        const result = viewer.setSurfaceAppearance(materialTarget.value as SurfaceKey, getMaterialValues());
        materialStatus.textContent = `Updated ${result.updated} material(s).`;
      });

      materialReset.addEventListener('click', () => {
        const result = viewer.resetSurfaceAppearance(materialTarget.value as SurfaceKey);
        materialStatus.textContent = `Reset ${result.updated} material(s).`;
      });

      if (viewer.isVRSupported()) {
        vrBtn.style.display = 'inline-block';
        vrBtn.addEventListener('click', () => {
          viewer.startVRSession(
            () => { vrBtn.textContent = 'Exit VR'; },
            () => { vrBtn.textContent = 'Enter VR'; }
          );
        });
      }

      roomSelect.addEventListener('change', async (event) => {
        const selectedId = (event.target as HTMLSelectElement).value;
        const room = await resolveRoomById(selectedId);
        if (!room) return;

        status.textContent = `Loading ${room.name}...`;
        await viewer.loadRoom(room);
        writeUrl(room.id);
      });

      window.addEventListener(
        'pagehide',
        () => {
          viewer?.dispose();
          for (const localUrl of localObjectUrls) {
            URL.revokeObjectURL(localUrl);
          }
        },
        { once: true }
      );
    </script>
  </body>
</html>
